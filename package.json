    "posthog-node": "^5.29.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.0",
    "server-only": "^0.0.1",
    "stripe": "^22.0.2",
    "tailwind-merge": "^3.5.0",
