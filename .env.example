# ============================================================================
# Segra — environment variables
# Copy to `.env.local` for local dev; add each as a Vercel project env var for
# preview and production. Never commit populated values.
# ============================================================================

# ---- App ----
# Public-facing origin. Used for Stripe success/cancel URLs, email links, etc.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# One of: development | preview | production
APP_ENV="development"

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the client bundle.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Database (Supabase Postgres, via Prisma) ----
# Pooled connection string for the Next.js server runtime.
DATABASE_URL=
# Direct (non-pooled) connection string for Prisma migrations.
DIRECT_URL=

# ---- Anthropic (Claude) ----
# Claude reads closing disclosures and receipts directly (vision-capable); no
# separate OCR step. See docs/adr/0006-claude-pdf-over-textract.md.
ANTHROPIC_API_KEY=

# ---- Stripe ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_DIY=
STRIPE_PRICE_ID_TIER_1=
STRIPE_PRICE_ID_TIER_2=

# ---- Resend (transactional email) ----
RESEND_API_KEY=
# Must be a verified domain sender, e.g. "Segra <noreply@segra.tax>".
RESEND_FROM_EMAIL=

# ---- Inngest (durable background jobs) ----
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ---- Sentry ----
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ---- PostHog ----
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
POSTHOG_API_KEY=

# ---- Google Maps (Places autocomplete in intake) ----
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ---- Upstash (rate limiting) ----
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Promo bypass (founder / QA only) ----
# When set, the `promoCode` field on the get-started form bypasses Stripe and
# creates the study directly (see lib/studies/bypass-checkout.ts). Leave unset
# in any production deployment — presence of the var enables the bypass path.
FISHER_PROMO_CODE=
