# ============================================================================
# Segra — environment variables
# Copy to `.env.local` for local dev; add each as a Vercel project env var for
# preview and production. Never commit populated values.
# ============================================================================

# ---- App ----
# Public-facing origin. Used for Stripe success/cancel URLs, email links, etc.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# One of: development | preview | production
APP_ENV="development"

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the client bundle.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Database (Supabase Postgres, via Prisma) ----
# Pooled connection string for the Next.js server runtime.
DATABASE_URL=
# Direct (non-pooled) connection string for Prisma migrations.
DIRECT_URL=

# ---- Anthropic (Claude) ----
# Claude reads closing disclosures and receipts directly (vision-capable); no
# separate OCR step. See docs/adr/0006-claude-pdf-over-textract.md.
ANTHROPIC_API_KEY=

# ---- Stripe ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_DIY=
STRIPE_PRICE_ID_TIER_1=
STRIPE_PRICE_ID_TIER_2=

# ---- Resend (transactional email) ----
RESEND_API_KEY=
# Must be a verified domain sender, e.g. "Segra <noreply@segra.tax>".
RESEND_FROM_EMAIL=

# ---- Inngest (durable background jobs) ----
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ---- Sentry ----
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ---- PostHog ----
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
POSTHOG_API_KEY=

# ---- Google Maps (Places autocomplete in intake) ----
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ---- Upstash (rate limiting) ----
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Promo bypass (founder / QA only) ----
# When set, the `promoCode` field on the get-started form bypasses Stripe and
# creates the study directly (see lib/studies/bypass-checkout.ts). Leave unset
# in any production deployment — presence of the var enables the bypass path.
FISHER_PROMO_CODE=

# ---- v2 report upgrade flags (see docs/adr/0008-0013 + v2.0 master prompt) ----
# All flags default OFF. Each is independent; flip in rollout order once the
# corresponding prerequisite is in place. Accepted truthy values: "1", "true"
# (case-insensitive). Anything else is treated as off.

# Phase 1 — per-photo vision pass (describe-photos step). Writes
# Document.photoAnalysis. Prereq: `prisma migrate deploy` has applied
# migration 20260420_v2_photo_analysis.
V2_REPORT_PHOTOS=

# Phase 2 — per-object classifier v2 with residual plug + 6 adjustment
# fields. Implies V2_REPORT_PHOTOS in practice (the classifier reads
# photoAnalysis when photos are present).
V2_REPORT_CLASSIFIER=

# Phase 3 — Anthropic web_search during classifier v2 for live retailer URLs
# on `pricesearch` items. Adds ~$1–2/study at $10/1000 searches. Requires
# web_search enabled on the Anthropic account.
V2_REPORT_WEB_SEARCH=

# Phase 4 — property enrichment via web_search against assessor + listing
# sites. Writes Property.enrichmentJson (migration
# 20260420_02_property_enrichment) and activates rule 2 (assessor ratio) in
# decompose-price@v2.
V2_REPORT_PROPERTY_ENRICH=

# Phase 5 — deliver step maps v2 schedule into AiReportProps with embedded
# photo data URIs + enrichment-aware Property Info page. Off path: PDF
# renders via v1 template even when schedule is v2-shaped.
V2_REPORT_PDF=

# Phase 7b — run vision-model QA review (rasterize rendered PDF, batch
# pages to Opus 4.7 with a severity/category rubric). Telemetry-only by
# default. PREREQ: `pnpm add pdf-to-png-converter` — the rasterizer dep
# is NOT declared in package.json; the review fails-soft with a clear
# error if the dep is missing.
V2_REPORT_REVIEW=

# Phase 7b enforce — when ON (and V2_REPORT_REVIEW is also on), any
# severity=blocker finding short-circuits delivery. Off = findings
# logged to StudyEvent only, delivery proceeds. Flip this AFTER a week
# of telemetry-only mode, once the false-positive rate is known.
V2_REPORT_REVIEW_ENFORCE=

# Max concurrent classify-document Anthropic calls (sonnet-4-6, short
# outputs). Default 3. Lower this if you hit the 30k input-TPM rate
# limit on sonnet-4-6; raise it once your org's rate tier allows.
AI_DOC_CONCURRENCY=

# Max concurrent describe-photos Anthropic calls (sonnet-4-6, heavy
# structured vision outputs ~1.5-2.5k tokens each). Default 2. Three in
# parallel bursts past the 8k output-TPM ceiling on sonnet-4-6.
AI_PHOTO_CONCURRENCY=
